# EditorConfig cross-platform para ASP.NET Core
# Compatible con Visual Studio, Rider, VS Code, y Neovim
# https://editorconfig.org

root = true

[*]
indent_style = space
indent_size = 4
# end_of_line NO se especifica: Git maneja CRLF/LF via .gitattributes
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[*.{cs,vb}]
# Convenciones de C# / VB.NET
indent_size = 4
indent_style = space

# Reglas de estilo Roslyn compatibles con VS
dotnet_style_qualification_for_event = false:silent
dotnet_style_qualification_for_field = false:silent
dotnet_style_qualification_for_method = false:silent
dotnet_style_qualification_for_property = false:silent
dotnet_style_predefined_type_for_locals_parameters_members = true:silent
dotnet_style_predefined_type_for_member_access = true:silent
dotnet_style_require_accessibility_modifiers = for_non_interface_members:silent
dotnet_style_object_initializer = true:suggestion
dotnet_style_collection_initializer = true:suggestion
dotnet_style_explicit_tuple_names = true:suggestion
dotnet_style_coalesce_expression = true:suggestion
dotnet_style_null_propagation = true:suggestion

# Reglas de naming (compatibles con analizadores de VS)
csharp_style_var_for_built_in_types = true:silent
csharp_style_var_when_type_is_apparent = true:silent
csharp_style_var_elsewhere = false:silent
csharp_style_expression_bodied_methods = false:silent
csharp_style_expression_bodied_constructors = false:silent
csharp_style_expression_bodied_properties = true:silent
csharp_style_pattern_matching = true:suggestion
csharp_style_throw_expression = true:suggestion

# Usings al estilo VS
csharp_using_directive_placement = outside_namespace:silent
dotnet_sort_system_directives_first = true

[*.{csproj,props,targets,xml,config}]
indent_size = 2
indent_style = space

[*.{json,jsonc}]
indent_size = 2
indent_style = space

[*.{razor,cshtml}]
indent_size = 4
indent_style = space

[*.yaml]
indent_size = 2
indent_style = space
